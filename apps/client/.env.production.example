# ==========================================
# TalentRadar Frontend - Production Environment Variables
# ==========================================
#
# IMPORTANT: This is an example file for production deployment.
# Copy this to .env.production and fill in your actual values.
# NEVER commit actual .env files to version control!
# ==========================================

# ==========================================
# Backend API Configuration
# ==========================================
# Backend API base URL (must include /api/v1 at the end)
# IMPORTANT: No trailing slash!
#
# Examples:
#   - Railway: https://talentradar-backend-production.up.railway.app/api/v1
#   - Render: https://talentradar-backend.onrender.com/api/v1
#   - GCP Cloud Run: https://talentradar-backend-xxxxx.run.app/api/v1
#   - Custom domain: https://api.talentradar.com/api/v1
VITE_API_URL=https://your-backend-url.railway.app/api/v1

# ==========================================
# Optional: Analytics & Monitoring
# ==========================================
# Uncomment and add if you're using these services

# Google Analytics
# VITE_GA_TRACKING_ID=G-XXXXXXXXXX

# Sentry (Error Tracking)
# VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Feature Flags
# VITE_ENABLE_FEATURE_X=true

# ==========================================
# Optional: Third-Party Services
# ==========================================
# Add any third-party service keys needed by frontend

# Stripe (if implementing payments)
# VITE_STRIPE_PUBLIC_KEY=pk_live_xxxxx

# Intercom (if implementing chat support)
# VITE_INTERCOM_APP_ID=xxxxx

# ==========================================
# Deployment Notes
# ==========================================
# Vercel:
#   1. Go to Project Settings → Environment Variables
#   2. Add VITE_API_URL with your backend URL
#   3. Redeploy to apply changes
#
# Netlify:
#   1. Go to Site Settings → Build & Deploy → Environment
#   2. Add VITE_API_URL
#   3. Trigger new deploy
#
# Important:
# - All Vite env vars MUST start with VITE_
# - Env vars are embedded in build (not runtime)
# - Rebuild/redeploy required for env var changes
# - Don't put secrets here (they're visible in client-side code!)
#
# Verification:
# After deployment, open browser console and check:
# console.log(import.meta.env.VITE_API_URL)
# Should show your backend URL
#
# Troubleshooting:
# - If API calls fail, verify VITE_API_URL is correct
# - Ensure backend CORS_ORIGIN matches frontend URL
# - Check browser Network tab for actual API endpoints
